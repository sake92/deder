amends "../../config/DederProject.pkl"

local const scalaVersions = List("2.12.21", "2.13.18", "3.7.4")

local const commonModules: List<ScalaModule> =
  scalaVersions
    .map((sv) ->
      new CreateCrossModules {
        root = "common"
        template = new {
          scalaVersion = sv
          deps {
            "com.softwaremill.sttp.client3::core::3.11.0"
          }
        }
        jsTemplate = (template.asJs()) {
          scalaJsVersion = "1.20.2"
        }
        nativeTemplate = (template.asNative()) {
          scalaNativeVersion = "0.5.10"
        }
      }
        .get
        .all
    )
    .flatten()

modules {
  ...commonModules
}

