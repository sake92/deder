//amends "../../config/DederProject.pkl"

//amends "https://sake92.github.io/deder/config/early-access/DederProject.pkl"

amends "https://sake92.github.io/deder/config/v0.5.0/DederProject.pkl"

local const baseModule: ScalaModule = new {
  scalaVersion = "3.7.4"
  publish = false
}

local const common = (baseModule) {
  id = "common"
  deps {
    "org.jsoup:jsoup:1.21.1"
  }
}

local const frontend = (baseModule) {
  id = "frontend"
  moduleDeps { common }
}

local const backendModules =
  new CreateScalaModules {
    root = "backend"
    template = (baseModule) {
      moduleDeps { common }
    }
    testTemplate = (template.asTest()) {
      deps {
        "org.scalameta::munit:1.2.1"
      }
    }
  }.get

local const uberModules =
  new CreateScalaModules {
    root = "uber"
    template = (baseModule) {
      moduleDeps {
        frontend
        backendModules.main
      }
      deps {
        "com.lihaoyi::pprint:0.9.5"
      }
      mainClass = "uber.Main"
      forkEnv {
        ["MY_VAR"] = "true"
      }
      jvmOptions {
        "-Xmx128m"
      }
    }
    testTemplate = (template.asTest()) {
      deps {
        "org.scalameta::munit:1.2.1"
      }
    }
  }.get

modules {
  common
  frontend
  ...backendModules.all
  ...uberModules.all
}
