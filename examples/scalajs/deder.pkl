
amends "../../config/DederProject.pkl"
//amends "https://sake92.github.io/deder/config/DederProject.pkl"

local const frontendModules = new CreateScalaJsModules {
  root = "frontend"
  template = new {
    scalaVersion = "3.7.1"
    scalaJsVersion = "1.20.2"
    moduleKind = "es-module"
    deps {
      "org.scala-js::scalajs-dom::2.2.0"
    }
  }
  testTemplate = (template.asTest()) {
    deps {
      "org.scalameta::munit::1.2.1"
    }
  }
}.get

local const backend: ScalaModule = new {
  id = "backend"
  scalaVersion = "3.7.1"
  deps {
    "ba.sake::sharaf-undertow:0.16.0"
    "org.jboss.xnio:xnio-nio:3.8.16.Final"
  }
  scalacOptions {
    "-Yretain-trees"
  }
}

modules {
  ...frontendModules.all
  backend
}
