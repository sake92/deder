amends "../../config/DederProject.pkl"
// use this in prod:
//amends "https://sake92.github.io/deder/config/early-access/DederProject.pkl"

local const lib1 = new ScalaModule {
  scalaVersion = "3.7.1"
  id = "lib1"
  deps {
    "ba.sake::sharaf-undertow:0.13.0"
  }
  // Publish to Sonatype Central for releases, or SonatypeSnapshotRepo for snapshots.
  // The `id` must match a key in ~/.deder/credentials.pkl.
  publishTo = new SonatypeCentralRepo {
    id = "sonatype-central"
  }
  // For SNAPSHOT versions, use SonatypeSnapshotRepo instead:
  // publishTo = new SonatypeSnapshotRepo { id = "sonatype-central" }
  pomSettings {
    groupId = "com.example"
    artifactId = "lib1"
    version = "0.0.1-SNAPSHOT"
    name = "Deder Publish Example"
    description = "Deder example library"
    url = "https://github.com/myuser/deder-example-library"
    licenses {
      new PomLicense {
        name = "MIT License"
        url = "http://www.opensource.org/licenses/mit-license.php"
      }
    }
    developers {
      new PomDeveloper {
        id = "myuser"
        name = "My User"
        email = "myuser@example.com"
      }
    }
    scm {
      url = "git@github.com:myuser/deder-example-library.git"
    }
  }
}

local const lib2 = (lib1) {
  id = "lib2"
  moduleDeps { lib1 }
  pomSettings {
    artifactId = "lib2"
  }
}

local const lib3 = (lib1) {
  id = "lib3"
  moduleDeps { lib2 }
  pomSettings {
    artifactId = "lib3"
  }
}

modules {
  lib1
  lib2
  lib3
}
