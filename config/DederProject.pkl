module ba.sake.deder.config.DederProject

// TODO write tests https://pkl-lang.org/blog/testing-in-pkl.html#writing-tests

/// list of modules in the project. Each module corresponds to a subproject with its own source directories, dependencies, and tasks.
modules: Listing<DederModule>(modulesValidation)

hidden modulesValidation = (value: Listing<DederModule>) ->
  if (!(value.toList().map((m) -> m.id).distinct.length == value.length))
    throw("Module ids must be unique.")
  else
    true

abstract class DederModule {
  /// Module id, used in CLI and referring from other modules
  id: String(idValidation)

  /// Module root directory, relative to project root
  root: String(rootValidation) = id

  /// Source directories, relative to module root. Defaults to `src`.
  sources: Listing<String> = new Listing { "src" }

  /// Module dependencies
  moduleDeps: Listing<DederModule>

  type: ModuleType

  hidden idValidation = (value: String) ->
    if (!value.matches(Regex("^[.a-zA-Z0-9_-]+$")))
      throw("Id must be alphanumeric and can contain '_' and '-' but got: " + value)
    else
      true

  hidden rootValidation = (value: String) ->
    if (!value.matches(Regex("^[.a-zA-Z0-9/_-]+$")))
      throw("Root must be alphanumeric and can contain '_', '-', and '/' but got: " + value)
    else
      true
}

typealias ModuleType =
  "java"
    | "java-test"
    | "scala"
    | "scala-test"
    | "scala-js"
    | "scala-js-test"
    | "scala-native"
    | "scala-native-test"

class PomLicense {
  /// SPDX identifier or full license name, e.g. "MIT" or "MIT License"
  name: String(!isEmpty)
  /// URL to the license text
  url: String(!isEmpty)
}
class PomDeveloper {
  id: String(!isEmpty)
  name: String(!isEmpty)
  email: String(!isEmpty)
}
class PomScm {
  /// URL of the SCM repository, e.g. GitHub URL
  url: String?
  /// SCM connection string, e.g. "scm:git:github.com:user/repo.git"
  connection: String?
  developerConnection: String?
  /// Optional tag/branch to point to, e.g. "v1.0.0" or "main". Not commonly used but can be helpful for linking to the exact code corresponding to a release.
  tag: String?
}
class PomSettings {
  /// Group ID for publishing, e.g. "com.example". Required for publishing to Maven Central. Not strictly required for local publishing but recommended to avoid conflicts.
  groupId: String(!isEmpty)
  /// Artifact ID for publishing, e.g. "my-library". Required for publishing to Maven Central. Not strictly required for local publishing but recommended to avoid conflicts.
  artifactId: String(!isEmpty)
  /// Version for publishing, e.g. "1.0.0". Required for publishing to Maven Central. Not strictly required for local publishing but recommended to avoid conflicts.
  /// If not provided, Deder will use a default semver versioning scheme based on git tags and commits (e.g. "0.1.0-SNAPSHOT" for a non-tagged commit, "1.0.0" for a commit tagged with "v1.0.0").
  version: String?
  name: String(!isEmpty) = artifactId
  description: String?
  url: String?
  licenses: Listing<PomLicense> = new Listing {}
  developers: Listing<PomDeveloper> = new Listing {}
  scm: PomScm?
}

class ManifestSettings {
  /// Main JAR manifest attributes, e.g. "Implementation-Version" -> "1.0.0"
  mainAttributes: Mapping<String, String> = new Mapping {}
  /// Named manifest entry groups (rarely needed)
  groups: Mapping<String, Mapping<String, String>> = new Mapping {}
}

class MvnApp {
  /// Maven dependency coordinate, e.g. "org.scalameta:scalafmt-cli_2.13:3.8.6"
  dep: String(!isEmpty)
  /// Fully qualified main class to run
  mainClass: String(!isEmpty)
  /// Arguments to pass to the main class when running the app. Can also be provided at runtime via `deder exec -t runMvnApp <name> -- [args...]`, which will be appended to these defaults.
  args: Listing<String> = new Listing {}
}

open class JavaModule extends DederModule {
  type = "java"
  /// Resource directories, relative to module root. Defaults to `resources/`.
  resources: Listing<String> = new Listing { "resources" }
  /// Java path to use for compilation and running. Can be a JDK path or a JDK version if using toolchains. If not provided, Deder will use the Java version running Deder server itself.
  javaHome: String?
  /// JVM options to use for running and testing
  jvmOptions: Listing<String> = new Listing {}
  /// Java version to use for compilation, e.g. "1.8", "11", "17". This is used for setting the `--release` flag during compilation and for selecting the appropriate Java runtime when running the app.
  javaVersion: String?
  javacOptions: Listing<String> = new Listing {}
  /// Environment variables to set when running/testing the app, e.g. "ENV_VAR" -> "value".
  forkEnv: Mapping<String, String> = new Mapping {}
  /// Main class to run
  mainClass: String?
  /// Dependencies to include when compiling/running the app
  deps: Listing<String> = new Listing {}
  javacAnnotationProcessorDeps: Listing<String> = new Listing {}
  javaSemanticdbVersion: String = "0.11.1"
  /// JAR manifest entries. Overrides defaults set by Deder.
  manifest: ManifestSettings = new ManifestSettings {}
  publish: Boolean = true
  pomSettings: PomSettings?
  /// Named maven apps that can be run via `deder exec -t runMvnApp <name> [args...]`.
  /// Server auto-provides `fmt`, `fmtCheck` (scalafmt) etc for scala modules.
  mvnApps: Mapping<String, MvnApp> = new Mapping {}
  function asTest(): JavaTestModule = (this.toDynamic().toTyped(JavaTestModule)) {
    type = "java-test"
    publish = false
  }
}

class JavaTestModule extends JavaModule {
  type = "java-test"
  publish = false
  /// Whether to run tests in a separate JVM process. By default, it's enabled for better isolation and to avoid classpath issues, but it can be disabled for faster test runs during development (not recommended for CI).
  fork: Boolean = true
  testFrameworks: Listing<String> = new Listing {
    "com.novocode.junit.JUnitFramework"
    "com.github.sbt.junit.jupiter.api.JupiterFramework"
  }
}

open class ScalaModule extends JavaModule {
  type = "scala"
  scalaVersion: String(!isEmpty)
  scalacOptions: Listing<String> = new Listing {}
  scalacPluginDeps: Listing<String> = new Listing {}
  scalaSemanticdbVersion: String?
  function asTest(): ScalaTestModule = (this.toDynamic().toTyped(ScalaTestModule)) {
    type = "scala-test"
    publish = false
  }
  function asJs(): ScalaJsModule = (this.toDynamic().toTyped(ScalaJsModule)) {
    type = "scala-js"
  }
  function asNative(): ScalaNativeModule = (this.toDynamic().toTyped(ScalaNativeModule)) {
    type = "scala-native"
  }
}

class ScalaTestModule extends ScalaModule {
  type = "scala-test"
  publish = false
  /// Whether to run tests in a separate JVM process. By default, it's enabled for better isolation and to avoid classpath issues, but it can be disabled for faster test runs during development (not recommended for CI).
  fork: Boolean = true
  testFrameworks: Listing<String> = new Listing {
    "com.novocode.junit.JUnitFramework"
    "com.github.sbt.junit.jupiter.api.JupiterFramework"
    "org.scalatest.tools.Framework"
    "org.specs2.runner.Specs2Framework"
    "munit.Framework"
    "utest.runner.Framework"
    "zio.test.sbt.ZTestFramework"
    "weaver.framework.CatsEffect"
  }
}

typealias ScalaJsModuleKind = "no-module" | "es-module" | "commonjs-module"

open class ScalaJsModule extends ScalaModule {
  type = "scala-js"
  scalaJsVersion: String(!isEmpty)
  moduleKind: ScalaJsModuleKind = "no-module"
  function asTest(): ScalaJsTestModule = (this.toDynamic().toTyped(ScalaJsTestModule)) {
    type = "scala-js-test"
    publish = false
  }
}

class ScalaJsTestModule extends ScalaJsModule {
  type = "scala-js-test"
  publish = false
  testFrameworks: Listing<String> = new Listing {
    "com.novocode.junit.JUnitFramework"
    "com.github.sbt.junit.jupiter.api.JupiterFramework"
    "org.scalatest.tools.Framework"
    "org.specs2.runner.Specs2Framework"
    "munit.Framework"
    "utest.runner.Framework"
    "zio.test.sbt.ZTestFramework"
    "weaver.framework.CatsEffect"
  }
}

typealias ScalaNativeGC = "none" | "boehm" | "immix" | "commix"
typealias ScalaNativeMode = "debug" | "release-fast" | "release-full" | "release-size"
typealias ScalaNativeLTO = "none" | "thin" | "full"

open class ScalaNativeModule extends ScalaModule {
  type = "scala-native"
  scalaNativeVersion: String(!isEmpty)
  /// Garbage collector algorithm. `immix` is the default and recommended for most use cases.
  gc: ScalaNativeGC = "immix"
  /// Build mode / optimization level. Use `debug` for development and `release-fast` or `release-full` for production.
  mode: ScalaNativeMode = "debug"
  /// Enable multithreading support. Requires a multithreading-capable GC (`immix` or `commix`).
  multithreading: Boolean = false
  /// Link-Time Optimization level. `thin` is a good balance for release builds.
  lto: ScalaNativeLTO = "none"
  /// Embed classpath resources into the native binary.
  embedResources: Boolean = false
  /// Extra linker flags, appended to auto-discovered options.
  nativeLinkingOptions: Listing<String> = new Listing {}
  /// Extra clang compile flags, appended to auto-discovered options.
  nativeCompileOptions: Listing<String> = new Listing {}
  function asTest(): ScalaNativeTestModule = (this.toDynamic().toTyped(ScalaNativeTestModule)) {
    type = "scala-native-test"
    publish = false
  }
}

class ScalaNativeTestModule extends ScalaNativeModule {
  type = "scala-native-test"
  publish = false
  testFrameworks: Listing<String> = new Listing {
    "com.novocode.junit.JUnitFramework"
    "com.github.sbt.junit.jupiter.api.JupiterFramework"
    "org.scalatest.tools.Framework"
    "org.specs2.runner.Specs2Framework"
    "munit.Framework"
    "utest.runner.Framework"
    "zio.test.sbt.ZTestFramework"
    "weaver.framework.CatsEffect"
  }
}

// helpers
// https://pkl-lang.org/blog/class-as-a-function.html

class ScalaModules {
  main: ScalaModule
  test: ScalaTestModule
  all: Listing<DederModule> = new { main; test }
}
class CreateScalaModules {
  root: String
  template: ScalaModule
  testTemplate: ScalaTestModule = template.asTest()
  fixed get: ScalaModules = scalaModules(template, testTemplate, root)
}

const function scalaModules(
  _template: ScalaModule,
  _testTemplate: ScalaTestModule,
  _root: String,
): ScalaModules = new {
  main = (_template) {
    id = _root.replaceAll("/", "-")
    root = _root
  }
  test = (_testTemplate) {
    id = "\(_root.replaceAll("/", "-"))-test"
    root = "\(_root)/test"
    moduleDeps {
      main
    }
  }
}

class ScalaJsModules {
  main: ScalaJsModule
  test: ScalaJsTestModule
  all: Listing<DederModule> = new { main; test }
}
class CreateScalaJsModules {
