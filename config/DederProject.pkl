class CrossModules {
  jvm: ScalaModule
  jvm_test: ScalaTestModule
  js: ScalaJsModule
  js_test: ScalaJsTestModule
  native: ScalaNativeModule
  native_test: ScalaNativeTestModule
  all: Listing<DederModule> = new { jvm; jvm_test; js; js_test; native; native_test }
}

class CreateCrossModules {
  template: ScalaModule
  testTemplate: ScalaTestModule = template.asTest()
  jsTemplate: ScalaJsModule = template.asJs()
  jsTestTemplate: ScalaJsTestModule = jsTemplate.asTest()
  nativeTemplate: ScalaNativeModule = template.asNative()
  nativeTestTemplate: ScalaNativeTestModule = nativeTemplate.asTest()
  root: String
  layout: DirLayout = "default"
  fixed get: CrossModules =
    crossModules(
      template,
      testTemplate,
      jsTemplate,
      jsTestTemplate,
      nativeTemplate,
      nativeTestTemplate,
      root,
      layout,
    )
}

const function crossModules(
  _template: ScalaModule,
  _testTemplate: ScalaTestModule,
  _jsTemplate: ScalaJsModule,
  _jsTestTemplate: ScalaJsTestModule,
  _nativeTemplate: ScalaNativeModule,
  _nativeTestTemplate: ScalaNativeTestModule,
  _root: String,
  _layout: DirLayout,
): CrossModules =
  let (cfg = resolveLayout(_layout, "scala"))
  let (jvmSuffix = "\(cfg.mainScalaSrcBase)-jvm")
  let (jsSuffix = "\(cfg.mainScalaSrcBase)-js")
  let (nativeSuffix = "\(cfg.mainScalaSrcBase)-native")
