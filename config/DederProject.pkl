module ba.sake.deder.config.DederProject

import "DederInternals.pkl" as I

// TODO write tests https://pkl-lang.org/blog/testing-in-pkl.html#writing-tests

/// list of modules in the project. Each module corresponds to a subproject with its own source directories, dependencies, and tasks.
modules: Listing<DederModule>(modulesValidation)

hidden modulesValidation = (value: Listing<DederModule>) ->
  if (!(value.toList().map((m) -> m.id).distinct.length == value.length))
    throw("Module ids must be unique.")
  else
    true

/// Additional Maven repositories for dependency resolution.
/// Tried in declared order, before default repositories.
repositories: Listing<MavenRepository> = new Listing {}

/// Include Maven Central and the Ivy2 local cache. Set to false for
/// air-gapped / internal-only resolution (e.g. via a corporate Nexus).
/// If false, `repositories` must be non-empty.
includeDefaultRepos: Boolean = true

class MavenRepository {
  /// Repository URL. Supports http(s):// and file:// schemes.
  /// Credentials (if required) come from Coursier's native config:
  /// ~/.config/coursier/credentials.properties or COURSIER_CREDENTIALS.
  url: String(!isEmpty)
}

abstract class DederModule {
  /// Module id, used in CLI and referring from other modules
  id: String(idValidation)

  /// Module root directory, relative to project root
  root: String(rootValidation) = id

  /// Source directories, relative to module root. Defaults to `src`.
  sources: Listing<String> = new Listing { "src" }

  /// Module dependencies
  moduleDeps: Listing<DederModule>

  type: ModuleType

  hidden idValidation = (value: String) ->
    if (!value.matches(Regex("^[.a-zA-Z0-9_-]+$")))
      throw("Id must be alphanumeric and can contain '_' and '-' but got: " + value)
    else
      true

  hidden rootValidation = (value: String) ->
    if (!value.matches(Regex("^[.a-zA-Z0-9/_-]+$")))
      throw("Root must be alphanumeric and can contain '_', '-', and '/' but got: " + value)
    else
      true
}

typealias ModuleType =
  "java"
    | "java-test"
    | "scala"
    | "scala-test"
    | "scala-js"
    | "scala-js-test"
    | "scala-native"
    | "scala-native-test"

/// Zinc compile order: controls the order in which Java and Scala sources are compiled.
/// `java-then-scala` (default): compile all Java first, then Scala. Standard for most projects.
/// `scala-then-java`: compile Scala first, then Java. Use when Java sources depend on Scala.
/// `mixed`: compile Java and Scala together in a single pass. Required when there are circular
///   dependencies between Java and Scala sources in the same module.
typealias CompileOrder = "java-then-scala" | "scala-then-java" | "mixed"

/// Controls source/resource directory layout convention.
/// `default` — Deder's own convention: sources and resources at module root level.
/// `maven` — Maven/SBT/Gradle convention: sources under `src/main/<lang>/` and `src/test/<lang>/`.
typealias DirLayout = "default" | "maven"

class PomLicense {
  /// SPDX identifier or full license name, e.g. "MIT" or "MIT License"
  name: String(!isEmpty)
  /// URL to the license text
  url: String(!isEmpty)
}
class PomDeveloper {
  id: String(!isEmpty)
  name: String(!isEmpty)
  email: String(!isEmpty)
}
class PomScm {
  /// URL of the SCM repository, e.g. GitHub URL
  url: String?
  /// SCM connection string, e.g. "scm:git:github.com:user/repo.git"
  connection: String?
  developerConnection: String?
  /// Optional tag/branch to point to, e.g. "v1.0.0" or "main". Not commonly used but can be helpful for linking to the exact code corresponding to a release.
  tag: String?
}
class PomSettings {
  /// Group ID for publishing, e.g. "com.example". Required for publishing to Maven Central. Not strictly required for local publishing but recommended to avoid conflicts.
  groupId: String(!isEmpty)
  /// Artifact ID for publishing, e.g. "my-library". Required for publishing to Maven Central. Not strictly required for local publishing but recommended to avoid conflicts.
  artifactId: String(!isEmpty)
  /// Version for publishing, e.g. "1.0.0". Required for publishing to Maven Central. Not strictly required for local publishing but recommended to avoid conflicts.
  /// If not provided, Deder will use a default semver versioning scheme based on git tags and commits (e.g. "0.1.0-SNAPSHOT" for a non-tagged commit, "1.0.0" for a commit tagged with "v1.0.0").
  version: String?
  name: String(!isEmpty) = artifactId
  description: String?
  url: String?
  licenses: Listing<PomLicense> = new Listing {}
  developers: Listing<PomDeveloper> = new Listing {}
  scm: PomScm?
}

class ManifestSettings {
  /// Main JAR manifest attributes, e.g. "Implementation-Version" -> "1.0.0"
  mainAttributes: Mapping<String, String> = new Mapping {}
  /// Named manifest entry groups (rarely needed)
  groups: Mapping<String, Mapping<String, String>> = new Mapping {}
}

class GraalVmSettings {
  /// Path to GraalVM home directory (must contain bin/native-image).
  /// If null, falls back to the GRAALVM_HOME environment variable.
  graalvmHome: String?
  /// Extra flags passed to the native-image tool, e.g. "--no-fallback"
  nativeImageOptions: Listing<String> = new Listing {}
}

class JUnitXmlReportSettings {
  /// When true, Deder writes one JUnit XML file per executed test suite/class.
  enabled: Boolean = false
  /// Optional report output directory. Relative paths resolve from the module root.
  /// If null, Deder writes to `.deder/out/<module>/<task>/reports/junit/`.
  outputDir: String?
}

class MvnApp {
  /// Maven dependency coordinate, e.g. "org.scalameta:scalafmt-cli_2.13:3.8.6"
  dep: String(!isEmpty)
  /// Fully qualified main class to run
  mainClass: String(!isEmpty)
  /// Arguments to pass to the main class when running the app. Can also be provided at runtime via `deder exec -t runMvnApp <name> -- [args...]`, which will be appended to these defaults.
  args: Listing<String> = new Listing {}
}

open class JavaModule extends DederModule {
  type = "java"
  /// Resource directories, relative to module root. Defaults to `resources/`.
  resources: Listing<String> = new Listing { "resources" }
  /// Java path to use for compilation and running. Can be a JDK path or a JDK version if using toolchains. If not provided, Deder will use the Java version running Deder server itself.
  javaHome: String?
  /// JVM options to use for running and testing, e.g. "-DXmx2g". These are not used for compilation, which uses `javacOptions` instead.
  jvmOptions: Listing<String> = new Listing {}
  /// Java version to use for compilation, e.g. "1.8", "11", "17". This is used for setting the `--release` flag during compilation and for selecting the appropriate Java runtime when running the app.
  javaVersion: String?
  /// Zinc compile order: controls how Java and Scala sources are ordered during compilation.
  /// `java-then-scala` (default): compile all Java first, then Scala. Standard for most projects.
  /// `scala-then-java`: compile Scala first, then Java. Use when Java sources depend on Scala types.
  /// `mixed`: compile Java and Scala together. Required when there are circular dependencies.
  compileOrder: CompileOrder = "java-then-scala"
  javacOptions: Listing<String> = new Listing {}
  /// Environment variables to set when running/testing the app, e.g. "ENV_VAR" -> "value".
  forkEnv: Mapping<String, String> = new Mapping {}
  /// Main class to run
  mainClass: String?
  /// Dependencies to include when compiling/running the app
  deps: Listing<String> = new Listing {}
  javacAnnotationProcessorDeps: Listing<String> = new Listing {}
  javaSemanticdbVersion: String = "0.11.1"
  /// Whether to generate SemanticDB during compilation (used by BSP/IDE features and scalafix).
  /// Defaults to true in local development, false in CI environments.
  semanticdbEnabled: Boolean = read?("env:CI") == null
  /// JAR manifest entries. Overrides defaults set by Deder.
  manifest: ManifestSettings = new ManifestSettings {}
  publish: Boolean = true
  pomSettings: PomSettings?
  /// GraalVM native image settings. When non-null, the nativeImage task is available for this module.
  graalvm: GraalVmSettings?
  /// Named maven apps that can be run via `deder exec -t runMvnApp <name> [args...]`.
  /// Server auto-provides `fmt`, `fmtCheck` (scalafmt) etc for scala modules.
  mvnApps: Mapping<String, MvnApp> = new Mapping {}
  function asTest(): JavaTestModule = (this.toDynamic().toTyped(JavaTestModule)) {
    type = "java-test"
    publish = false
  }
}

class JavaTestModule extends JavaModule {
  type = "java-test"
  publish = false
  /// Number of test classes to run in parallel within a single test JVM.
  /// 0 (default) = use all available CPU cores. Set to 1 for serial execution.
  /// Only safe to increase if tests have no shared static state, System.setProperty calls, or shared temp files.
  testParallelism: Int(isBetween(0, 256)) = 0
  /// Maximum number of forked JVMs to spawn for running this module's tests.
  /// Effective fork count is min(maxTestForks, number of discovered test classes).
  /// 0 (default) = use all available CPU cores. Each fork pays JVM startup cost and holds its own heap.
  /// Capped server-wide by the maxConcurrentTestForks server property.
  maxTestForks: Int(isBetween(0, 64)) = 0
  junitXmlReport: JUnitXmlReportSettings?
  testFrameworks: Listing<String> = new Listing {
    "com.novocode.junit.JUnitFramework"
    "com.github.sbt.junit.jupiter.api.JupiterFramework"
  }
}

open class ScalaModule extends JavaModule {
  type = "scala"
  scalaVersion: String(!isEmpty) // TODO validate semver-ish format
  scalacOptions: Listing<String> = new Listing {}
  scalacPluginDeps: Listing<String> = new Listing {}
  scalaSemanticdbVersion: String?
  function asTest(): ScalaTestModule = (this.toDynamic().toTyped(ScalaTestModule)) {
    type = "scala-test"
    publish = false
  }
  function asJs(): ScalaJsModule = (this.toDynamic().toTyped(ScalaJsModule)) {
    type = "scala-js"
  }
  function asNative(): ScalaNativeModule = (this.toDynamic().toTyped(ScalaNativeModule)) {
    type = "scala-native"
  }
}

class ScalaTestModule extends ScalaModule {
  type = "scala-test"
  publish = false
  /// Number of test classes to run in parallel within a single test JVM.
  /// 0 (default) = use all available CPU cores. Set to 1 for serial execution.
  /// Only safe to increase if tests have no shared static state, System.setProperty calls, or shared temp files.
  testParallelism: Int(isBetween(0, 256)) = 0
  /// Maximum number of forked JVMs to spawn for running this module's tests.
  /// Effective fork count is min(maxTestForks, number of discovered test classes).
  /// 0 (default) = use all available CPU cores. Each fork pays JVM startup cost and holds its own heap.
  /// Capped server-wide by the maxConcurrentTestForks server property.
  maxTestForks: Int(isBetween(0, 64)) = 0
  junitXmlReport: JUnitXmlReportSettings?
  testFrameworks: Listing<String> = new Listing {
    "com.novocode.junit.JUnitFramework"
    "com.github.sbt.junit.jupiter.api.JupiterFramework"
    "org.scalatest.tools.Framework"
    "org.specs2.runner.Specs2Framework"
    "munit.Framework"
    "utest.runner.Framework"
    "zio.test.sbt.ZTestFramework"
    "weaver.framework.CatsEffect"
  }
}

typealias ScalaJsModuleKind = "no-module" | "es-module" | "commonjs-module"

typealias ScalaJsModuleSplitStyle = "fewest-modules" | "smallest-modules" | "small-modules-for"

typealias ScalaJsESVersion =
  "es2015" | "es2016" | "es2017" | "es2018" | "es2019" | "es2020" | "es2021"

class ScalaJsLinkerConfig {
  /// How to split output into multiple JS modules.
  /// `fewest-modules` (default): bundles aggressively, fewer larger files.
  /// `smallest-modules`: splits ~1 class per file, better for caching/incremental downstream tooling.
  /// `small-modules-for`: splits only listed packages (see `smallModulesFor`).
  moduleSplitStyle: ScalaJsModuleSplitStyle = "fewest-modules"

  /// Packages to split when `moduleSplitStyle = "small-modules-for"`. Must be non-empty.
  smallModulesFor: Listing<String> = new Listing {}

  /// ECMAScript version assumed available at runtime. Enables polyfill dead-code-elimination.
  /// Use `es2018`+ for modern Node.js/browsers.
  esVersion: ScalaJsESVersion = "es2015"

  /// Emit source maps for debugging generated JS. Turn off to reduce file count.
  sourceMap: Boolean = true

  /// Enable Scala.js optimizer (dead-code elimination, method inlining). Disable for faster dev linking.
  optimizer: Boolean = true

  /// Apply Scala.js minification (identifier shortening). Does NOT affect runtime performance.
  minify: Boolean = false

  /// Production mode semantics: removes debug assertions, enables aggressive optimizations.
  productionMode: Boolean = false

  /// JS comment prepended to every generated `.js` file. Must end with `\n`.
  jsHeader: String = ""

  /// Pretty-print generated JavaScript. Useful for debugging linker output.
  prettyPrint: Boolean = false

  /// Java Formatter pattern for JS output filenames, e.g. "%s.mjs" for Node.js ES modules.
  jsOutputPattern: String = "%s.js"

  /// Avoid JS `class` syntax in favor of `function`/`prototype` when semantics are identical.
  avoidClasses: Boolean = true

  /// Avoid `let`/`const` in favor of `var` when semantics are identical.
  avoidLetsAndConsts: Boolean = true

  /// Perform expensive IR validity checks during linking. For debugging linker/compiler bugs.
  checkIR: Boolean = false

  /// Base URI to relativize source map paths against. Useful for deployable source maps.
  relativizeSourceMapBase: String?

  /// Discard intermediate linker state for one-shot builds (CI). Default false for watch mode.
  batchMode: Boolean = false

  /// Maximum concurrent file writes during linking. Tune lower for slow/network filesystems.
  maxConcurrentWrites: Int(isBetween(1, 256)) = 50

  /// EXPERIMENTAL: Compile `scala.Long` as JavaScript `bigint` instead of runtime-emulated 64-bit integers.
  allowBigIntsForLongs: Boolean = false

  /// EXPERIMENTAL: Use the WebAssembly backend instead of JavaScript. Requires `moduleKind = "es-module"` and `esVersion >= es2015`.
  experimentalUseWebAssembly: Boolean = false
}

open class ScalaJsModule extends ScalaModule {
  type = "scala-js"
  scalaJsVersion: String(!isEmpty)
  moduleKind: ScalaJsModuleKind = "no-module"
  /// Scala.js linker configuration. Fine-grained control over linking behavior.
  linkerConfig: ScalaJsLinkerConfig = new ScalaJsLinkerConfig {}
  function asTest(): ScalaJsTestModule = (this.toDynamic().toTyped(ScalaJsTestModule)) {
    type = "scala-js-test"
    publish = false
  }
}

class ScalaJsTestModule extends ScalaJsModule {
  type = "scala-js-test"
  publish = false
  /// Number of test classes to run in parallel within a single test JVM.
  /// 0 (default) = use all available CPU cores. Set to 1 for serial execution.
  /// Only safe to increase if tests have no shared static state, System.setProperty calls, or shared temp files.
  testParallelism: Int(isBetween(0, 256)) = 0
  junitXmlReport: JUnitXmlReportSettings?
  testFrameworks: Listing<String> = new Listing {
    "com.novocode.junit.JUnitFramework"
    "com.github.sbt.junit.jupiter.api.JupiterFramework"
    "org.scalatest.tools.Framework"
    "org.specs2.runner.Specs2Framework"
    "munit.Framework"
    "utest.runner.Framework"
    "zio.test.sbt.ZTestFramework"
    "weaver.framework.CatsEffect"
  }
}

typealias ScalaNativeGC = "none" | "boehm" | "immix" | "commix"
typealias ScalaNativeMode = "debug" | "release-fast" | "release-full" | "release-size"
typealias ScalaNativeLTO = "none" | "thin" | "full"

open class ScalaNativeModule extends ScalaModule {
  type = "scala-native"
  scalaNativeVersion: String(!isEmpty)
  /// Garbage collector algorithm. `immix` is the default and recommended for most use cases.
  gc: ScalaNativeGC = "immix"
  /// Build mode / optimization level. Use `debug` for development and `release-fast` or `release-full` for production.
  mode: ScalaNativeMode = "debug"
  /// Enable multithreading support. Requires a multithreading-capable GC (`immix` or `commix`).
  multithreading: Boolean = false
  /// Link-Time Optimization level. `thin` is a good balance for release builds.
  lto: ScalaNativeLTO = "none"
  /// Embed classpath resources into the native binary.
  embedResources: Boolean = false
  /// Extra linker flags, appended to auto-discovered options.
  nativeLinkingOptions: Listing<String> = new Listing {}
  /// Extra clang compile flags, appended to auto-discovered options.
  nativeCompileOptions: Listing<String> = new Listing {}
  function asTest(): ScalaNativeTestModule = (this.toDynamic().toTyped(ScalaNativeTestModule)) {
    type = "scala-native-test"
    publish = false
  }
}

class ScalaNativeTestModule extends ScalaNativeModule {
  type = "scala-native-test"
  publish = false
  /// Number of test classes to run in parallel within a single test JVM.
  /// 0 (default) = use all available CPU cores. Set to 1 for serial execution.
  /// Only safe to increase if tests have no shared static state, System.setProperty calls, or shared temp files.
  testParallelism: Int(isBetween(0, 256)) = 0
  junitXmlReport: JUnitXmlReportSettings?
  testFrameworks: Listing<String> = new Listing {
    "com.novocode.junit.JUnitFramework"
    "com.github.sbt.junit.jupiter.api.JupiterFramework"
    "org.scalatest.tools.Framework"
    "org.specs2.runner.Specs2Framework"
    "munit.Framework"
    "utest.runner.Framework"
    "zio.test.sbt.ZTestFramework"
    "weaver.framework.CatsEffect"
  }
}

// helpers
// https://pkl-lang.org/blog/class-as-a-function.html

const function resolveLayout(layout: DirLayout, lang: String): I.LayoutConfig =
  if (layout == "maven")
    if (lang == "scala")
      new I.LayoutConfig {
        mainScalaSrcBase = "src/main/scala"
        testScalaSrcBase = "src/test/scala"
        mainExtraSrc { "src/main/java" }
        testExtraSrc { "src/test/java" }
        mainResources { "src/main/resources" }
        testResources { "src/test/resources" }
        testRootSuffix = ""
      }
    else // "java"
      new I.LayoutConfig {
        mainScalaSrcBase = "src/main/java"
        testScalaSrcBase = "src/test/java"
        mainExtraSrc {}
        testExtraSrc {}
        mainResources { "src/main/resources" }
        testResources { "src/test/resources" }
        testRootSuffix = ""
      }
  else // "default"
    new I.LayoutConfig {
      mainScalaSrcBase = "src"
      testScalaSrcBase = "src"
      mainExtraSrc {}
      testExtraSrc {}
      mainResources { "resources" }
      testResources { "resources" }
      testRootSuffix = "/test"
    }

class JavaModules {
  main: JavaModule
  test: JavaTestModule
  all: Listing<DederModule> = new { main; test }
}
class CreateJavaModules {
  root: String
  template: JavaModule
  testTemplate: JavaTestModule = template.asTest()
  layout: DirLayout = "default"
  fixed get: JavaModules = javaModules(template, testTemplate, root, layout)
}

const function javaModules(
  _template: JavaModule,
  _testTemplate: JavaTestModule,
  _root: String,
  _layout: DirLayout,
): JavaModules =
  let (cfg = resolveLayout(_layout, "java"))
    new {
      main = (_template) {
        id = _root.replaceAll("/", "-")
        root = _root
        sources = new Listing {
          cfg.mainScalaSrcBase
          ...(cfg.mainExtraSrc)
        }
        resources = cfg.mainResources
      }
      test = (_testTemplate) {
        id = "\(_root.replaceAll("/", "-"))-test"
        root = "\(_root)\(cfg.testRootSuffix)"
        sources = new Listing {
          cfg.testScalaSrcBase
          ...(cfg.testExtraSrc)
        }
        resources = cfg.testResources
        moduleDeps {
          main
        }
      }
    }

class ScalaModules {
  main: ScalaModule
  test: ScalaTestModule
  all: Listing<DederModule> = new { main; test }
}
class CreateScalaModules {
  root: String
  template: ScalaModule
  testTemplate: ScalaTestModule = template.asTest()
  layout: DirLayout = "default"
  fixed get: ScalaModules = scalaModules(template, testTemplate, root, layout)
}

const function scalaModules(
  _template: ScalaModule,
  _testTemplate: ScalaTestModule,
  _root: String,
  _layout: DirLayout,
): ScalaModules =
  let (cfg = resolveLayout(_layout, "scala"))
    new {
      main = (_template) {
        id = _root.replaceAll("/", "-")
        root = _root
        sources = new Listing {
          cfg.mainScalaSrcBase
          ...(cfg.mainExtraSrc)
          for (prefix in I.versionPrefixes(_template.scalaVersion)) {
            "\(cfg.mainScalaSrcBase)-\(prefix)"
          }
        }
        resources = cfg.mainResources
      }
      test = (_testTemplate) {
        id = "\(_root.replaceAll("/", "-"))-test"
        root = "\(_root)\(cfg.testRootSuffix)"
        sources = new Listing {
          cfg.testScalaSrcBase
          ...(cfg.testExtraSrc)
          for (prefix in I.versionPrefixes(_template.scalaVersion)) {
            "\(cfg.testScalaSrcBase)-\(prefix)"
          }
        }
        resources = cfg.testResources
        moduleDeps {
          main
        }
      }
    }

