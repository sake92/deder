module ba.sake.deder.config.DederCredentials

/// Credentials for publishing artifacts to remote repositories.
/// This file should be stored at `~/.deder/credentials.pkl` and kept secret (not committed to version control).
///
/// Example:
/// ```pkl
/// amends "https://sake92.github.io/deder/config/v0.8.0/DederCredentials.pkl"
///
/// credentials {
///   ["sonatype-central"] = new SonatypeCentralCredentials {
///     username = "myuser"
///     password = "mytoken"
///     pgpSecret = "base64-encoded-secret-key"
///     pgpPassphrase = "my-passphrase"
///   }
/// }
/// ```
credentials: Mapping<String, RepoCredentials> = new Mapping {}

/// Base class for repository credentials.
abstract class RepoCredentials {}

/// Credentials for Sonatype Central (releases). Requires PGP signing.
class SonatypeCentralCredentials extends RepoCredentials {
  /// Sonatype Central username (User Token username from https://central.sonatype.com/account).
  username: String(!isEmpty)
  /// Sonatype Central password (User Token password from https://central.sonatype.com/account).
  password: String(!isEmpty)
  /// Base64-encoded PGP secret key (output of `gpg --export-secret-keys | base64`).
  pgpSecret: String(!isEmpty)
  /// Passphrase for the PGP secret key.
  pgpPassphrase: String(!isEmpty)
}

/// Credentials for Sonatype Central Snapshots. No PGP signing required.
class SonatypeSnapshotCredentials extends RepoCredentials {
  /// Sonatype Central username.
  username: String(!isEmpty)
  /// Sonatype Central password.
  password: String(!isEmpty)
}

/// Basic username/password credentials for any Maven-compatible repository.
class BasicAuthCredentials extends RepoCredentials {
  username: String(!isEmpty)
  password: String(!isEmpty)
}
