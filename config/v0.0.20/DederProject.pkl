}

class CrossModules {
  jvm: ScalaModule
  jvm_test: ScalaTestModule
  js: ScalaJsModule
  js_test: ScalaJsTestModule
  native: ScalaNativeModule
  native_test: ScalaNativeTestModule
  all: Listing<DederModule> = new { jvm; jvm_test; js; js_test; native; native_test }
}

class CreateCrossModules {
  template: ScalaModule
  testTemplate: ScalaTestModule = template.asTest()
  jsTemplate: ScalaJsModule = template.asJs()
  jsTestTemplate: ScalaJsTestModule = jsTemplate.asTest()
  nativeTemplate: ScalaNativeModule = template.asNative()
  nativeTestTemplate: ScalaNativeTestModule = nativeTemplate.asTest()
  root: String
  fixed get: CrossModules =
    crossModules(
      template,
      testTemplate,
      jsTemplate,
      jsTestTemplate,
      nativeTemplate,
      nativeTestTemplate,
      root,
    )
}

const function crossModules(
  _template: ScalaModule,
  _testTemplate: ScalaTestModule,
  _jsTemplate: ScalaJsModule,
  _jsTestTemplate: ScalaJsTestModule,
  _nativeTemplate: ScalaNativeModule,
  _nativeTestTemplate: ScalaNativeTestModule,
  _root: String,
): CrossModules = new {
  jvm = (_template) {
    id = "\(_root)-jvm-\(_template.scalaVersion)"
    root = _root
    sources {
      "src-jvm"
    }
  }
  jvm_test = (_testTemplate) {
    id = "\(_root)-jvm-test-\(_template.scalaVersion)"
    root = "\(_root)/test"
    sources {
      "src-jvm"
    }
    moduleDeps {
      jvm
    }
  }
  js = (_jsTemplate) {
    id = "\(_root)-js-\(_template.scalaVersion)"
    root = _root
    sources {
      "src-js"
    }
  }
  js_test = (_jsTestTemplate) {
    id = "\(_root)-js-test-\(_template.scalaVersion)"
    root = "\(_root)/test"
    sources {
      "src-js"
    }
    moduleDeps {
      js
    }
  }
  native = (_nativeTemplate) {
    id = "\(_root)-native-\(_template.scalaVersion)"
    root = _root
    sources {
      "src-native"
    }
  }
  native_test = (_nativeTestTemplate) {
    id = "\(_root)-native-test-\(_template.scalaVersion)"
    root = "\(_root)/test"
    sources {
      "src-native"
    }
    moduleDeps {
      native
    }
  }
}
