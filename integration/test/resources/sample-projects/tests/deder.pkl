amends "../../../../../config/DederProject.pkl"

const local function javaTestModule(name: String) = new JavaTestModule {
  id = name
  root = name
  fork = true
}

const local function scalaTestModule(name: String) = new ScalaTestModule {
  id = name
  root = name
  scalaVersion = "3.7.1"
  fork = true
}


local const junit4 = (javaTestModule("junit4")) {
  deps {
    "com.github.sbt:junit-interface:0.13.2"
    "junit:junit:4.13"
  }
}

local const junit5 = (javaTestModule("junit5")) {
  deps {
    "com.github.sbt.junit:jupiter-interface:0.16.0"
    "org.junit.jupiter:junit-jupiter-api:5.10.1"
  }
}

local const scalatest = (scalaTestModule("scalatest")) {
  deps {
    "org.scalatest::scalatest:3.2.19"
  }
}

local const specs2 = (scalaTestModule("specs2")) {
  deps {
    "org.specs2::specs2-core:5.7.0"
  }
}

local const munit = (scalaTestModule("munit")) {
  deps {
    "org.scalameta::munit:1.2.1"
  }
}

local const utest = (scalaTestModule("utest")) {
  deps {
    "com.lihaoyi::utest:0.10.0-RC1"
  }
}

local const weaver = (scalaTestModule("weaver")) {
  deps {
    "org.typelevel::weaver-cats:0.11.3"
  }
}

local const ztest = (scalaTestModule("ztest")) {
  deps {
    "dev.zio::zio-test:2.1.24"
    "dev.zio::zio-test-sbt:2.1.24"
  }
}

modules {
  junit4
  junit5
  scalatest
  specs2
  munit
  utest
  weaver
  ztest
}
