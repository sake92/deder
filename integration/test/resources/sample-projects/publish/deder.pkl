amends "../../../../../config/DederProject.pkl"

local const lib1 = new ScalaModule {
  scalaVersion = "3.7.1"
  id = "lib1"
  deps {
    "com.lihaoyi::os-lib:0.11.6"
  }
  pomSettings = makePomSettings("lib1")
  manifest {
    mainAttributes {
      ["Implementation-Version"] = "0.0.1-SNAPSHOT"
      ["Implementation-Title"] = "lib1"
    }
  }
}

local const lib2 = new ScalaModule {
  scalaVersion = "3.7.1"
  id = "lib2"
  moduleDeps {
    lib1
  }
  pomSettings = makePomSettings("lib2")
}

local const lib3 = new ScalaModule {
  scalaVersion = "3.7.1"
  id = "lib3"
  moduleDeps {
    lib2
  }
  pomSettings = makePomSettings("lib3")
}

local const lib4 = new ScalaModule {
  scalaVersion = "3.7.1"
  id = "lib4"
  moduleDeps {
    lib1
    lib2
  }
  pomSettings = makePomSettings("lib4")
}

local const lib5 = new ScalaModule {
  scalaVersion = "3.7.1"
  id = "lib5"
  root = "lib5"
  pomSettings = makePomSettings("lib5")
  publishLocalTo = "out/local-repo"
}

modules {
  lib1
  lib2
  lib3
  lib4
  lib5
}

local const function makePomSettings(_artifactId: String): PomSettings = new {
  groupId = "com.example"
  artifactId = _artifactId
  version = "0.0.1-SNAPSHOT"
  name = "Deder Example"
  description = "Deder example"
  url = "https://github.com/myuser/deder-example"
  licenses {
    new PomLicense {
      name = "MIT License"
      url = "http://www.opensource.org/licenses/mit-license.php"
    }
  }
  developers {
    new PomDeveloper {
      id = "myuser"
      name = "My User"
      email = "myuser@example.com"
    }
  }
  scm {
    url = "git@github.com:myuser/deder-example.git"
  }
}
