amends "../../../../../config/DederProject.pkl"

local const cliModules = new CreateScalaNativeModules {
  root = "cli"
  template = new {
    publish = false
    scalaVersion = "3.7.4"
    scalaNativeVersion = "0.5.10"
  }
  testTemplate = (template.asTest()) {
    deps {
      "org.scalameta::munit::1.2.1"
    }
  }
}.get

modules {
  ...cliModules.all
}
